# 数据库配置
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/safety_monitoring
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# 安全配置
SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_SECONDS=3600

# 服务器配置
HOST=0.0.0.0
PORT=8000
DEBUG=False

# 文件存储配置
EVIDENCE_DIR=static/evidence
CALIBRATION_TEMP_DIR=static/calibration_temp
CALIBRATION_SCRIPT_PATH=scripts/calibration_tool.py
MAX_UPLOAD_SIZE=10485760

# CORS配置
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 设备心跳配置
HEARTBEAT_TIMEOUT_SECONDS=300

# Edge 零配置引导（Bootstrap）
# BOOTSTRAP_SECRET=  留空则开放，生产环境建议设置

# 设备状态检测配置
DEVICE_STATUS_CHECK_INTERVAL=2
DEVICE_STATUS_CHECK_ENABLED=True
