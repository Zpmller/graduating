  "dependencies": {
    "@element-plus/icons-vue": "^2.1.0",
    "axios": "^1.4.0",
    "dayjs": "^1.11.0",
    "echarts": "^5.4.0",
    "element-plus": "^2.3.0",
    "pinia": "^2.1.0",
    "socket.io-client": "^4.7.0",
    "vue": "^3.3.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^18.16.0",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "@vitejs/plugin-vue": "^4.2.0",
    "@vue/eslint-config-typescript": "^11.0.0",
    "@vue/test-utils": "^2.4.1",
    "@vue/tsconfig": "^0.4.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.40.0",
    "eslint-plugin-vue": "^9.11.0",
    "jsdom": "^22.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "typescript": "~5.0.2",
